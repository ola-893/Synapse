# =============================================================================
# Synapse Environment Configuration
# =============================================================================

# --- Sui Network ---
SUI_NETWORK=testnet
SUI_PRIVATE_KEY=                     # suiprivkey1... or raw hex

# --- Walrus Blob Storage ---
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# --- MemWal (Persistent Agent Memory) ---
MEMWAL_DELEGATE_KEY=                 # Delegate key from MemWal dashboard
MEMWAL_ACCOUNT_ID=                   # Account ID from MemWal dashboard
MEMWAL_SERVER_URL=                   # MemWal relayer URL (leave blank for fallback mode)
MEMWAL_NAMESPACE=synapse-agent       # Namespace prefix for agent memory

# --- Seal (Threshold Encryption) ---
SEAL_PACKAGE_ID=0x984960ebddd75c15c6d38355ac462621db0ffc7d6647214c802cd3b685e1af3d
SEAL_KEY_SERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
SEAL_KEY_SERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8

# --- Synapse On-Chain Contracts ---
SYNAPSE_PACKAGE_ID=0x_placeholder_synapse_package_id
MARKETPLACE_REGISTRY_ID=0x_placeholder_marketplace_id

# --- AI ---
GEMINI_API_KEY=                      # Google Gemini API key

# --- Storage Driver ---
STORAGE_DRIVER=mock                  # 'walrus' for real Walrus, 'mock' for local testing

# --- Server ---
PORT=3002
AUTO_START=false                     # Auto-start agent runtime on server boot

# --- Frontend ---
VITE_API_URL=http://localhost:3002
